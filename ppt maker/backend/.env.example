# SlideGen AI — Backend environment
# Copy to `backend/.env` (optional; shell exports also work).
#
#   cp .env.example .env              # macOS/Linux
#   copy .env.example .env            # Windows

# --- AI (recommended for production quality) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_DOCUMENT_CHARS=48000
OPENAI_ANALYSIS_MAX_SLIDES=14
OPENAI_MAX_SUMMARY_CHARS=12000

# --- Database (optional) ---
# Omit to use JSON file store under backend/data/
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/slidegen_ai?schema=public

# --- Storage & exports ---
STORAGE_BACKEND=local
EXPORT_ASYNC=false

# --- AWS S3 (optional, future) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
