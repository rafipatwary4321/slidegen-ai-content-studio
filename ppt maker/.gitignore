# --- Dependencies ---
node_modules/

# --- Next.js ---
.next/
out/

# --- Python ---
venv/
.venv/
backend/.venv/
backend/venv/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Environment & secrets (never commit) ---
.env
.env.local
.env.*.local
.env.development.local
.env.production.local
.env.test.local
.env.*
!.env.example
!.env.local.example

# --- Build output ---
dist/
build/

