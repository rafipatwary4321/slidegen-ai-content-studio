# SlideGen AI Content Studio — Frontend environment
# Repository: slidegen-ai-content-studio
#
# Copy to `.env.local` before running the app (never commit `.env.local`):
#
#   cp .env.example .env.local        # macOS/Linux
#   copy .env.example .env.local      # Windows
#
# Start web + API: npm run dev:clean   (recommended)
#                  npm run dev:all     (without cache clear)

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-min-32-chars
